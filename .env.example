# RestroSync Environment Configuration
# Copy this file to .env and fill in the values

# Server
SERVER_HOST=127.0.0.1
SERVER_PORT=3001

# PostgreSQL
DATABASE_URL=postgres://restrosync:restrosync_dev@localhost:5432/restrosync
DATABASE_MAX_CONNECTIONS=10

# Redis
REDIS_URL=redis://localhost:6379

# NATS
NATS_URL=nats://localhost:4222

# Meilisearch
MEILI_URL=http://localhost:7700
MEILI_MASTER_KEY=restrosync_dev_key

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRY_HOURS=24

# Logging
RUST_LOG=info,restrosync=debug
